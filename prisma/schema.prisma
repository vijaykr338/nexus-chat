// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  participants Participant[]
  messages     Message[]

  sentRequests  FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")


  @@index([username])
}

//adding friend requests into the picture

model GroupJoinRequest {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  status         RequestStatus
  createdAt      DateTime @default(now())

  @@unique([userId, conversationId])
}

model Friendship {
  id      String @id @default(uuid())
  user1Id String
  user2Id String

  @@unique([user1Id, user2Id])
}

model FriendRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      RequestStatus
  createdAt   DateTime @default(now())

  sender      User @relation("SentRequests", fields: [senderId], references: [id])
  receiver    User @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

enum RequestStatus{
  PENDING
  ACCEPTED
  REJECTED
}

model Conversation {
  id        String   @id @default(uuid())
  type      ConversationType
  name      String?
  createdAt DateTime @default(now())

  participants Participant[]
  messages     Message[]

  @@index([type, name])
  @@index([name])
  //the type, name order here is crucial
}

enum ConversationType {
  DIRECT
  GROUP
}

model Participant {
  id             String @id @default(uuid())
  userId         String
  conversationId String
  role           Role   @default(MEMBER)

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
  @@index([conversationId])
}

enum Role {
  ADMIN
  MEMBER
}

//explaination about the Message and MessageStatus tables

//Message contains the senderID, the creator of the message 
//MessageStatus decides what each user who has recieved this message
//have they seen it or not seen it 
//the creator does not need a STATUS row
// Message:
// A sends: "hello"
// Status:
// B → ✔✔ delivered
// C → ✔✔ blue (seen)
// D → ✔ sent only

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String

  type MessageType

  content  String?   // text or caption
  fileUrl  String?   // media
  fileName String?
  fileSize Int?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  statuses MessageStatus[]

  @@index([conversationId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
}

model MessageStatus {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  status    Status
  updatedAt DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id])

  @@unique([messageId, userId])
  //good for finding messages which are unread
  //crucial for finding everything 
  @@index([userId, status])
  
}

enum Status {
  SENT
  DELIVERED
  SEEN
}